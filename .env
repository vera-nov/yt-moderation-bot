YT_CHANNEL_ID= # youtube advanced settings (profile -> settings -> advanced settings -> channel ID)
YT_FETCH_LIMIT=100
YT_POLL_INTERVAL_SEC=60 # api call interval in seconds
YT_TEXT_FORMAT=plainText # default is html
YT_MIN_COMMENT_AGE_SEC=180 # ignore fresh comments
YT_QUOTA_DAILY_LIMIT=10000
YT_QUOTA_STOP_PERCENT=0.95
ENABLE_REPLY_SCAN=true
MODERATION_BATCH_SIZE=5 # delete simultaneously
DRY_RUN=false

TG_BOT_TOKEN= # on bot creation (via BotFather)
TG_ADMIN_USER_ID= # get via curl -s "https://api.telegram.org/bot${TG_BOT_TOKEN}/getUpdates"
TG_ADMIN_CHAT_ID=

PROCESSED_TTL_DAYS=30 # processed comments
AUDIT_TTL_DAYS=30 # event log
STOP_WORDS_FILE=/home/naganai/ytbot/stop_words.txt
SQLITE_PATH=/home/naganai/ytbot/state.sqlite
CLIENT_SECRET_PATH=/home/naganai/ytbot/client_secret_test.json # get from google cloud
TOKEN_PATH=token.json # create upon bot launch